pipeline {
    agent any

    tools {
        nodejs 'NodeJs'
    }
     environment {
        SONAR_TOKEN = credentials('SonarQube')
    }
    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/vpolagani80-art/demo-project.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run App') {
            steps {
                sh 'nohup npm start > app.log 2>&1 &'
            }
        }
           stage('SonarQube') {
            steps {
                 withSonarQubeEnv(credentialsId: 'jenkin2-access') 
                      sh 'npm clean package sonar:sonar'

                    }
                }
            }
        }
